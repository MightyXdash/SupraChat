{
  "name": "suprachat",
  "productName": "SupraChat",
  "version": "0.1.0",
  "private": true,
  "description": "Interface to try SupraLabs' models",
  "author": {
    "name": "SupraLabs",
    "url": "https://github.com/MightyXdash/SupraChat"
  },
  "homepage": "https://github.com/MightyXdash/SupraChat",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/MightyXdash/SupraChat.git"
  },
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:ui\" \"npm:dev:electron\"",
    "dev:ui": "vite --host 127.0.0.1",
    "dev:electron": "npm run rebuild:electron && wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev:node": "node backend/node/server.cjs",
    "build": "vite build",
    "rebuild:electron": "electron-rebuild --force --only better-sqlite3",
    "resources:stage": "node scripts/stage-release-resources.cjs",
    "build:electron": "npm run models:download && npm run resources:stage && npm run runtime:check && npm run rebuild:electron && vite build && electron-builder",
    "build:electron:current": "npm run models:download && npm run resources:stage && npm run runtime:check && npm run rebuild:electron && vite build && electron-builder",
    "build:windows:x64": "npm run models:download && npm run resources:stage -- --platform win32 --arch x64 && node scripts/check-runtime.cjs --target --platform win32 --arch x64 --resource-root release-resources && npm run rebuild:electron && vite build && electron-builder --win --x64",
    "runtime:download": "node scripts/download-llama-runtime.cjs",
    "models:download": "node scripts/download-llama-models.cjs",
    "publish:release": "cross-env EP_DRAFT=false EP_PRE_RELEASE=false npm run build:electron -- --publish always",
    "publish:prerelease": "cross-env EP_DRAFT=false EP_PRE_RELEASE=true npm run build:electron -- --publish always",
    "release:signing:check": "node scripts/check-release-signing.cjs",
    "release:validate": "node scripts/validate-release-tag.cjs",
    "runtime:check": "node scripts/check-runtime.cjs",
    "runtime:check:all": "node scripts/check-runtime.cjs --all",
    "test:updater": "node --test electron/updater/__tests__/*.test.cjs",
    "preview": "vite preview",
    "postinstall": "node -e \"console.log('Skipping Electron native rebuild on install; run npm run rebuild:electron before packaging.')\""
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@radix-ui/react-slot": "^1.2.3",
    "axios": "^1.11.0",
    "better-sqlite3": "^12.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.554.0",
    "onnxruntime-node": "^1.27.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sherpa-onnx-node": "^1.13.3",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^38.1.2",
    "electron-builder": "^26.0.12",
    "shadcn": "^4.2.5",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.supralabs.suprachat",
    "icon": "build/icon.png",
    "productName": "SupraChat",
    "copyright": "Copyright © 2026 SupraLabs. Licensed under the GNU General Public License v3.0 (GPL-3.0).",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "backend/node/**/*",
      "package.json"
    ],
    "extraResources": [
    {
      "from": "release-resources",
      "to": "resources",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "build/icon.png",
      "to": "icon.png"
    }
  ],
    "directories": {
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "MightyXdash",
        "repo": "SupraChat"
      }
    ],
    "win": {
      "artifactName": "SupraChat-Setup-${version}.${ext}",
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "SupraChat",
      "installerHeader": "build/installer-header.bmp",
      "installerSidebar": "build/installer-sidebar.bmp",
      "uninstallerSidebar": "build/installer-sidebar.bmp"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "background": "build/dmg-background.png",
      "writeUpdateInfo": false,
      "contents": [
        {
          "x": 350,
          "y": 420,
          "type": "file"
        },
        {
          "x": 850,
          "y": 420,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 1200,
        "height": 800
      }
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
