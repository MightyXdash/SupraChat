{
  "name": "suprachat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:ui\" \"npm:dev:electron\"",
    "dev:ui": "vite --host 127.0.0.1",
    "dev:electron": "npm run rebuild:electron && wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev:node": "node backend/node/server.cjs",
    "build": "vite build",
    "rebuild:electron": "electron-rebuild --force --only better-sqlite3",
    "build:electron": "npm run models:download && npm run rebuild:electron && vite build && electron-builder",
    "models:download": "node scripts/download-llama-models.cjs",
    "runtime:check": "node scripts/check-runtime.cjs",
    "runtime:check:all": "node scripts/check-runtime.cjs --all",
    "preview": "vite preview",
    "postinstall": "node -e \"console.log('Skipping Electron native rebuild on install; run npm run rebuild:electron before packaging.')\""
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@radix-ui/react-slot": "^1.2.3",
    "axios": "^1.11.0",
    "better-sqlite3": "^12.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.554.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^38.1.2",
    "electron-builder": "^26.0.12",
    "shadcn": "^4.2.5",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.suprachat.app",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "backend/node/**/*",
      "resources/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "**/*"
        ]
      }
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
